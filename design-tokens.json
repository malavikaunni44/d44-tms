        "$description": "Small elevation — cards, dropdowns"
      },
      "medium": {
        "$value": "0px 12px 16px -8px rgba(56, 54, 212, 0.08), 0px 2px 2px 0px rgba(56, 54, 212, 0.07), 0px -1px 2px 0px rgba(56, 54, 212, 0.02)",
        "$type": "shadow",
        "$description": "Medium elevation — dialogs, modals, popovers"
      }
