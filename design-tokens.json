    "$description": "Elevation shadows using the brand indigo (#3836d4) as shadow color.",
    "light": {
      "small": {
        "$value": "0px 4px 16px -8px rgba(56, 54, 212, 0.16), 0px 0px 1px 0px rgba(56, 54, 212, 0.5)",
